# functions/.secret.local — llaves de Flow para el EMULADOR y fuente para subirlas.
# Copia a `functions/.secret.local` (gitignored) y pega tus llaves reales.
#   - El emulador de Functions lo lee automáticamente.
#   - `scripts/flow-secrets.sh` sube estas mismas a Secret Manager para el deploy.
# El par no usado puede ir dummy, pero los cuatro deben existir para deployar.

FLOW_SANDBOX_API_KEY=
FLOW_SANDBOX_SECRET_KEY=
FLOW_PRODUCTION_API_KEY=
FLOW_PRODUCTION_SECRET_KEY=
