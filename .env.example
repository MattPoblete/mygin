# ─── MyGin — Variables de entorno (ejemplo) ──────────────────────────────────
# Copia a `.env.local` y completa los valores. NUNCA commitees `.env.local`.

# ── Firebase Web (público, pero fuera del código por higiene) ──
# Obtén estos valores con:
#   npx -y firebase-tools@latest apps:sdkconfig WEB <APP_ID> --project theirgin
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (servidor / SSR privilegiado) ──
# JSON de service account (una sola línea) o usa ADC (GOOGLE_APPLICATION_CREDENTIALS).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ── Flow (pasarela de pago) — SOLO en Cloud Functions Secret Manager ──
# Modo de pago (env de las Functions): mock (default) | sandbox | production.
# UNA sola variable decide todo: si se llama a Flow, qué base URL y qué llaves.
# PAYMENTS_MODE=mock
#
# Dos pares de llaves coexisten (promover a prod = cambiar PAYMENTS_MODE):
# firebase functions:secrets:set FLOW_SANDBOX_API_KEY
# firebase functions:secrets:set FLOW_SANDBOX_SECRET_KEY
# firebase functions:secrets:set FLOW_PRODUCTION_API_KEY
# firebase functions:secrets:set FLOW_PRODUCTION_SECRET_KEY
#
# Emulador local con Flow real: functions/.secret.local (gitignored) con esas 4.

# ── App Check / reCAPTCHA (anti-spam en writes públicos) ──
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
